{
  "name": "pdf-generator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --bun next dev -p 10300",
    "build": "sh scripts/build-with-count.sh",
    "build:prod": "NODE_ENV=production next build",
    "postbuild": "bun scripts/generate-build-hash.ts",
    "start": "sh scripts/start-with-port.sh",
    "start:prod": "NODE_ENV=production next start",
    "cached-build-serve": "bun scripts/cached-build-serve.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "test:e2e": "bun test e2e/tests/**/*.test.ts",
    "test:e2e:watch": "bun test --watch e2e/tests/**/*.test.ts",
    "format": "biome format --write .",
    "lint": "biome check --write .",
    "pdf": "bun scripts/pdf/pdf.ts --resumePath=resumes --resumeType=single-column --prod",
    "pdf:anon": "bun scripts/pdf/pdf.ts --resumePath=resumes --anon --resumeType=single-column --prod",
    "pdf:resume": "bun scripts/pdf/pdf.ts --resumePath=resumes --resumeType=single-column --print=resume --prod",
    "pdf:cover": "bun scripts/pdf/pdf.ts --resumePath=resumes --resumeType=single-column --print=cover --prod",
    "typecheck": "tsc",
    "prepare": "husky",
    "watch:data": "nodemon --exec \"node watcher.cjs\" --watch \"$PII_PATH/data.yml\" --watch data.yml",
    "watch:pii": "bun scripts/watch-pii.ts",
    "yml-to-json": "bun lib/ymlToJson.ts",
    "yml-to-json:watch": "nodemon --watch . --ext yml --exec 'bun lib/ymlToJson.ts'",
    "init:multi-resume": "node scripts/init-multi-resume.js",
    "test:file-health": "node scripts/test-file-health.js"
  },
  "packageManager": "bun@1.3.3",
  "dependencies": {
    "@headlessui/react": "^2.2.7",
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-toast": "^1.2.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "diff": "^8.0.2",
    "dotenv": "^17.2.2",
    "next": "^16.0.1",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "^5.3.31",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "yaml": "^2.8.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@commitlint/cli": "^19.4.1",
    "@commitlint/config-conventional": "^19.4.1",
    "@commitlint/types": "^20.0.0",
    "@tailwindcss/postcss": "^4.0.5",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.9",
    "@types/diff": "^8.0.0",
    "@types/node": "^20.11.19",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/testing-library__react": "^10.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "chokidar": "^5.0.0",
    "husky": "^9.1.5",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.2.10",
    "nodemon": "^3.1.10",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.5.4",
    "puppeteer": "^23.4.1",
    "tailwindcss": "^4.0.5",
    "tsx": "^4.7.1",
    "typescript": "^5.2.2",
    "vite": "^7.1.10",
    "vitest": "^3.2.3"
  }
}
