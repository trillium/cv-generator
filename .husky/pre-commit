lint-staged
output_files="eslint-errors.txt output_*.pdf *.log *.tmp *.bak"

for pattern in $output_files; do
	# Convert glob pattern to regex: * becomes .*
	regex_pattern=$(echo "$pattern" | sed 's/\.\*/\\&/g; s/\*/\.\*/g')
	if git diff --cached --name-only | grep -E "^$regex_pattern\$"; then
		echo "❌ Commit rejected: Output files ($pattern) must not be committed."
		exit 1
	fi
done
